# ── Application ──
APP_NAME=IndustrialSafetyIntelligence
APP_VERSION=0.1.0
APP_ENV=development
DEBUG=true

# ── Database ──
DATABASE_URL=sqlite+aiosqlite:///./sensor_intelligence.db

# ── API ──
API_PREFIX=/api/v1
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# ── Messaging ──
EVENT_BROKER=noop

# ── Logging ──
LOG_LEVEL=INFO
