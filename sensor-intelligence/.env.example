# ── Application ──
APP_NAME=SensorIntelligence
APP_VERSION=0.1.0
APP_ENV=development
DEBUG=true

# ── Database ──
# SQLite (local development)
DATABASE_URL=sqlite+aiosqlite:///./sensor_intelligence.db

# PostgreSQL (production — uncomment to switch)
# DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/sensor_intelligence

# ── API ──
API_PREFIX=/api/v1
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# ── Messaging (future) ──
# EVENT_BROKER=noop
# KAFKA_BOOTSTRAP_SERVERS=localhost:9092
# MQTT_BROKER_URL=mqtt://localhost:1883

# ── Logging ──
LOG_LEVEL=INFO
